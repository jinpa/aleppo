{
  "name": "aleppo",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "patchedDependencies": {
      "expo-image-manipulator@55.0.10": "patches/expo-image-manipulator@55.0.10.patch"
    }
  },
  "scripts": {
    "dev:web": "pnpm --filter @aleppo/web dev",
    "build:web": "pnpm --filter @aleppo/web build",
    "start": "pnpm --filter @aleppo/web start",
    "build:railway": "sh scripts/build-spa.sh && pnpm --filter @aleppo/web build:railway",
    "start:railway": "pnpm --filter @aleppo/web start:railway"
  },
  "dependencies": {
    "pnpm": "^10.32.0"
  }
}
